# Contract addresses (set after deployment)
NEXT_PUBLIC_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VERIFIER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_NETWORK_NAME=localhost

# Optional RPC override for frontend reads/simulations
# NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545

# IPFS upload token (Pinata JWT)
PINATA_JWT=

# Relayer wallet config (required for /api/relay)
RELAYER_RPC_URL=http://127.0.0.1:8545
RELAYER_PRIVATE_KEY=

# Relayer chain: 31337 (Hardhat) or 11155111 (Sepolia)
RELAYER_CHAIN_ID=31337

# Backward compatibility aliases (optional)
# SEPOLIA_RPC_URL=
# SEPOLIA_PRIVATE_KEY=
